@page
@model LavanderiaWeb.Pages.Clientes.IndexModel
@{
    ViewData["Title"] = "Clientes";
}

<!-- Encabezado de página -->
<div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-8">
    <div>
        <h1 class="text-2xl font-bold text-slate-800 tracking-tight">Clientes</h1>
        <p class="text-sm text-slate-500 mt-0.5">Gestiona los clientes registrados en el sistema.</p>
    </div>
    <a asp-page="/Clientes/Crear"
           class="btn bg-indigo-600 hover:bg-indigo-700 text-white border-0 shadow-sm gap-2 self-start sm:self-auto">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
        </svg>
        Nuevo Cliente
    </a>
</div>

<!-- Tarjeta con la tabla -->
<div class="bg-white rounded-2xl shadow-sm border border-slate-100 overflow-hidden">

    <!-- Barra superior de la tabla -->
    <div class="px-6 py-4 border-b border-slate-100 flex items-center justify-between">
        <div class="flex items-center gap-2">
            <div class="w-2 h-2 rounded-full bg-indigo-500"></div>
            <span class="text-sm font-semibold text-slate-700">
                @Model.Clientes.Count cliente@(Model.Clientes.Count != 1 ? "s" : "") registrado@(Model.Clientes.Count != 1 ? "s" : "")
            </span>
        </div>
    </div>

    @if (!Model.Clientes.Any())
    {
        <!-- Estado vacío -->
        <div class="flex flex-col items-center justify-center py-20 text-slate-400">
            <svg class="w-14 h-14 mb-4 text-slate-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                      d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <p class="font-semibold text-slate-500 text-base">Sin clientes registrados</p>
            <p class="text-sm mt-1">Agrega el primer cliente usando el botón de arriba.</p>
        </div>
    }
    else
    {
        <div class="overflow-x-auto">
            <table class="table w-full">
                <thead>
                    <tr class="bg-slate-50 text-slate-500 text-xs uppercase tracking-wider font-semibold border-b border-slate-100">
                        <th class="px-6 py-3 font-semibold">#</th>
                        <th class="px-6 py-3 font-semibold">Cliente</th>
                        <th class="px-6 py-3 font-semibold">Teléfono</th>
                        <th class="px-6 py-3 font-semibold">Suscripción</th>
                        <th class="px-6 py-3 font-semibold text-right">Acciones</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-50">
                    @foreach (var cliente in Model.Clientes)
                    {
                        <tr class="hover:bg-slate-50/60 transition-colors">
                            <!-- ID -->
                            <td class="px-6 py-4">
                                <span class="font-mono text-xs text-slate-400">#@cliente.idCliente</span>
                            </td>

                            <!-- Nombre con avatar inicial -->
                            <td class="px-6 py-4">
                                <div class="flex items-center gap-3">
                                    <div class="w-9 h-9 rounded-full bg-indigo-100 flex items-center justify-center flex-shrink-0">
                                        <span class="text-sm font-bold text-indigo-600">
                                            @(cliente.nombre?.Length > 0 ? cliente.nombre[0].ToString().ToUpper() : "?")
                                        </span>
                                    </div>
                                    <span class="font-medium text-slate-800 text-sm">@cliente.nombre</span>
                                </div>
                            </td>

                            <!-- Teléfono -->
                            <td class="px-6 py-4">
                                <span class="font-mono text-sm text-slate-600">@cliente.telefono</span>
                            </td>

                            <!-- Suscripción con badge -->
                            <td class="px-6 py-4">
                                @if (cliente.tipoSub != null)
                                {
                                    <span class="badge badge-sm gap-1 font-medium px-2.5 py-1.5
                                        @(cliente.tipoSub.nombre == "Premium" ? "bg-amber-100 text-amber-700 border-amber-200" :
                                                                                    cliente.tipoSub.nombre == "Básico" ? "bg-sky-100 text-sky-700 border-sky-200" :
                                                                                                                            "bg-emerald-100 text-emerald-700 border-emerald-200")">
                                        @cliente.tipoSub.nombre
                                    </span>
                                }
                                else
                                {
                                    <span class="text-slate-400 text-xs italic">Sin suscripción</span>
                                }
                            </td>

                            <!-- Acciones -->
                            <td class="px-6 py-4 text-right">
                                <div class="flex items-center justify-end gap-1">
                                    <a asp-page="/Clientes/Editar" asp-route-id="@cliente.idCliente"
                                           class="btn btn-ghost btn-xs text-slate-500 hover:text-indigo-600 hover:bg-indigo-50 gap-1">
                                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                                  d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                                        </svg>
                                        Editar
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
